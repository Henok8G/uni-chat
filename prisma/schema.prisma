generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  universityId       String?
  emailVerified      Boolean             @default(false)
  plan               Plan                @default(FREE)
  planExpiresAt      DateTime?
  gender             Gender              @default(UNSPECIFIED)
  banned             Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  department         String?
  hobbies            String[]            @default([])
  year               Int?
  themeColor         String?
  sessionsA          ChatSession[]       @relation("sessionsA")
  sessionsB          ChatSession[]       @relation("sessionsB")
  deviceLogs         DeviceLog[]
  reportsReceived    Report[]            @relation("reportsReceived")
  reportsMade        Report[]            @relation("reportsMade")
  university         University?         @relation(fields: [universityId], references: [id])
  verificationTokens VerificationToken[] @relation("userVerificationTokens")
}

model University {
  id        String   @id @default(cuid())
  name      String
  domain    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model DeviceLog {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String
  userAgent String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id               String         @id @default(cuid())
  reporterId       String
  reportedUserId   String
  roomId           String?
  reason           String?
  createdAt        DateTime       @default(now())
  resolved         Boolean        @default(false)
  actionTaken      String?
  chatSessionId    String?
  details          String?
  handledByAdminId String?
  reasonCategory   ReasonCategory @default(OTHER)
  resolutionNotes  String?
  status           ReportStatus   @default(OPEN)
  chatSession      ChatSession?   @relation(fields: [chatSessionId], references: [id])
  reportedUser     User           @relation("reportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reporter         User           @relation("reportsMade", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model ChatSession {
  id          String              @id @default(cuid())
  userAId     String
  userBId     String
  startedAt   DateTime            @default(now())
  endedAt     DateTime?
  endedReason SessionEndedReason?
  ipA         String?
  ipB         String?
  planA       Plan                @default(FREE)
  planB       Plan                @default(FREE)
  userA       User                @relation("sessionsA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User                @relation("sessionsB", fields: [userBId], references: [id], onDelete: Cascade)
  reports     Report[]

  @@index([startedAt])
  @@index([userAId])
  @@index([userBId])
}

model VerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  user      User      @relation("userVerificationTokens", fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id           String   @id @default(cuid())
  type         String
  userId       String?
  sessionId    String?
  universityId String?
  plan         Plan?
  properties   Json?
  createdAt    DateTime @default(now())

  @@index([type, createdAt])
  @@index([userId])
  @@index([sessionId])
  @@index([universityId])
}

enum Plan {
  FREE
  STANDARD
  PRO
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

enum ReasonCategory {
  NUDITY
  HARASSMENT
  SPAM
  HATE
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWED
  ACTION_TAKEN
  DISMISSED
}

enum SessionEndedReason {
  NORMAL
  NEXT
  DISCONNECT
  REPORTED
  BANNED
  ERROR
}
