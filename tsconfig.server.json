{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": ".",
    "noEmit": false,
    "target": "ES2019",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["server.ts"],
  "exclude": ["node_modules", ".next", "src"]
}
